# ─── Secrets — NEVER commit these ────────────────────────────────────────────
*.key
*.pem
*.p12
*.pfx
cosign.key
cosign.pub
secrets/
*-secret.yaml
*-credentials.yaml
*-values-secret.yaml

# ─── Local CA certs (generated at runtime) ───────────────────────────────────
/tmp/*.crt
ztcr-ca.crt

# ─── Helm working files ───────────────────────────────────────────────────────
charts/
*.tgz

# ─── Kubeconfig ───────────────────────────────────────────────────────────────
kubeconfig
.kubeconfig
*.kubeconfig

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ─── Editors ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.swn

# ─── Runtime artifacts ────────────────────────────────────────────────────────
*.log
*.tmp
